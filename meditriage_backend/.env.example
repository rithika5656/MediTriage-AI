# ─────────────────────────────────────────────────────────
#  MediTriage – AI Health Core  |  Backend .env Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit your real .env to version control!
# ─────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=django-insecure-REPLACE-WITH-A-LONG-RANDOM-STRING-IN-PRODUCTION
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── AI Provider ───────────────────────────────────────────
# Set LLM_PROVIDER to "groq" (free, fast) or "openai" (powerful)
LLM_PROVIDER=groq

# Groq API Key (free tier available at https://console.groq.com)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY_HERE

# OpenAI API Key (optional fallback — https://platform.openai.com)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# ── Database ──────────────────────────────────────────────
# SQLite (development default — no setup needed)
# DB_ENGINE=sqlite3

# PostgreSQL (recommended for production)
DB_NAME=meditriage
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432
